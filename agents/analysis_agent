# Analysis Agent - synthesizes findings from all other agents.
# Specialist in combining climate data, events, and weather into insights.

from langchain.core.tools import tool
from langchain.ollama import ChatOllama
from langgraph.prebuilt import create_react_agent

from tools.nasa_power import get_climate_data, get_temperature_trend, format_climate_summary, format_trend_summary
from tools.nasa_eonet import get_event_statistics, format_stats_summary
from tools.open_meteo import get_historical_climate, format_historical_summary

MODEL = "llama3.1:8b"

SYSTEM_PROMPT = """
You are a Senior Climate Research Analyst.
Your role is to:
- Synthesise data from multiple sources (NASA POWER, NASA EONET, Open-Meteo)
- Identify connections between climate trends and natural events
- Draw evidence-based conclusions about climate patterns
- Provide clear, well-structured research summaries
- Highlight areas of concern or notable findings

Use your tools to gather data from multiple sources, then combine the findings
into a comprehensive analysis. Always back your conclusions with specific data.
Write in a clear, professional style suitable for a research report.
"""

@tool
def analyse_location_climate(lat: float, lon: float) -> str:
    """
    Perform a comprehensive climate analysis for a location.
    Fetches NASA POWER 30-year averages AND recent temperature trend.
    Use for deep climate analysis of a specific place.

    Parameters:
    lat (float): Latitude
    lon (float): Longitude
    """
    climate = get_climate_data(lat, lon)
    trend = get_temperature_trend(lat, lon, 2000, 2023)
    return format_climate_summary(climate) + "\n\n--TEMPERATURE TREND--\n" + format_trend_summary(trend)


@tool
def analyse_global_events(days: int = 90) -> str:
    """
    Analyse global natural event patterns over a time period.
    Combines event counts and recent events for a full picture.

    Parameters:
    days (int): Analysis period (default 90 days)
    """
    stats = get_event_statistics(days=days)
    return format_stats_summary(stats)


@tool
def compare_historical_weather(
    lat: float, lon: float,
    period1_start: str, period1_end: str,
    period2_start: str, period2_end: str
) -> str:
    """
    Compare weather between two time periods for the same location.
    Use to identify climate changes over time.

    Parameters:
    lat (float): Latitude
    lon (float): Longitude
    period1_start (str): Start date of first period (YYYY-MM-DD)
    period1_end (str): End date of first period
    period2_start (str): Start date of second period
    period2_end (str): End date of second period
    """
    p1 = get_historical_climate(lat, lon, period1_start, period1_end)
    p2 = get_historical_climate(lat, lon, period2_start, period2_end)

    s1 = p1.get("summary", {})
    s2 = p2.get("summary", {})

    lines = [
        f"Weather Comparison for ({lat}, {lon})",
        f"Period 1: {period1_start} to {period1_end}",
        f" - Avg temp: {s1.get('avg_temp_c', 'N/A')} °C",
        f" - Max temp: {s1.get('max_temp_c', 'N/A')} °C",
        f" - Total precip: {s1.get('total_precip_mm', 'N/A')} mm",
        f"Period 2: {period2_start} to {period2_end}",
        f" - Avg temp: {s2.get('avg_temp_c', 'N/A')} °C",
        f" - Max temp: {s2.get('max_temp_c', 'N/A')} °C",
        f" - Total precip: {s2.get('total_precip_mm', 'N/A')} mm",
    ]

    # Calculate differences
    if s1.get("avg_temp_c") is not None and s2.get("avg_temp_c") is not None:
        diff = round(s2["avg_temp_c"] - s1["avg_temp_c"], 2)
        lines.append(f"\nTemperature change: {diff:+} °C")
    if s1.get("total_precip_mm") is not None and s2.get("total_precip_mm") is not None:
        diff_p = round(s2["total_precip_mm"] - s1["total_precip_mm"], 1)
        lines.append(f"Precipitation change: {diff_p} mm")

    return "\n".join(lines)


def build_analysis_agent():
    """Build and return the Analysis Agent."""
    model = ChatOllama(model=MODEL, temperature=0)
    tools = [analyse_location_climate, analyse_global_events, compare_historical_weather]
    return create_react_agent(model, tools, prompt=SYSTEM_PROMPT)


def run_analysis_agent(question: str) -> str:
    """Run the analysis agent on a question and return its answer."""
    agent = build_analysis_agent()
    result = agent.invoke({"messages": [("human", question)]})
    return result["messages"][-1].content
